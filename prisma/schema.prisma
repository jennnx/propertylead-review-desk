// Prisma schema for Triage OS infrastructure baseline.
//
// This file deliberately defines no product/domain models. It exists so
// Prisma client generation, migrations, and the pgvector extension are
// wired up. Tracer feature slices add real models when they need them.
//
// In Prisma 7 the `url` no longer lives in the datasource block — the
// connection URL is read from the process environment by `prisma.config.ts`
// for migration commands, and is supplied to the runtime PrismaClient via a
// driver adapter (@prisma/adapter-pg).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum HubSpotWebhookEventProcessingStatus {
  NEW        @map("new")
  PROCESSING @map("processing")
  PROCESSED  @map("processed")
  FAILED     @map("failed")
  IGNORED    @map("ignored")
}

enum HubSpotWorkflowRunStatus {
  IN_PROGRESS @map("in_progress")
  SUCCEEDED   @map("succeeded")
  FAILED      @map("failed")
}

enum HubSpotWorkflowRunOutcome {
  NO_WRITEBACK_NEEDED @map("no_writeback_needed")
  WRITEBACK_PROPOSED  @map("writeback_proposed")
}

enum HubSpotWritebackState {
  PENDING      @map("pending")
  APPLIED      @map("applied")
  AUTO_APPLIED @map("auto_applied")
  REJECTED     @map("rejected")
}

enum SopDocumentProcessingStatus {
  PROCESSING @map("processing")
  READY      @map("ready")
  FAILED     @map("failed")
}

enum LlmCallProvider {
  ANTHROPIC @map("anthropic")
  VOYAGE    @map("voyage")
}

enum LlmCallSource {
  PRODUCTION @map("production")
  EVAL       @map("eval")
}

enum LlmCallStatus {
  OK    @map("ok")
  ERROR @map("error")
}

model HubSpotWebhookEvent {
  id               String                              @id @default(cuid())
  dedupeKey        String                              @unique
  rawWebhook       Json
  normalizedEvent  Json
  receivedAt       DateTime                            @default(now())
  processingStatus HubSpotWebhookEventProcessingStatus @default(NEW)
  processedAt      DateTime?
  workflowRun      HubSpotWorkflowRun?

  @@index([processingStatus, receivedAt])
  @@map("hubspot_webhook_events")
}

model HubSpotWorkflowRun {
  id                     String                     @id @default(cuid())
  hubSpotWebhookEventId  String                     @unique
  hubSpotWebhookEvent    HubSpotWebhookEvent        @relation(fields: [hubSpotWebhookEventId], references: [id], onDelete: Cascade)
  status                 HubSpotWorkflowRunStatus   @default(IN_PROGRESS)
  outcome                HubSpotWorkflowRunOutcome?
  enrichmentInputContext Json?
  writebackPlanInput     Json?
  writebackPlanRawOutputs Json?
  writebackPlanValidations Json?
  writebackPlan          Json?
  failureMessage         String?
  completedAt            DateTime?
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  hubSpotWriteback       HubSpotWriteback?
  llmCalls               LlmCall[]

  @@index([status, createdAt])
  @@map("hubspot_workflow_runs")
}

model HubSpotWriteback {
  id                     String                @id @default(cuid())
  hubSpotWorkflowRunId   String                @unique
  hubSpotWorkflowRun     HubSpotWorkflowRun    @relation(fields: [hubSpotWorkflowRunId], references: [id], onDelete: Cascade)
  plan                   Json
  state                  HubSpotWritebackState @default(PENDING)
  reviewDeskFeedbackNote String?
  appliedAt              DateTime?
  applicationMetadata    Json?
  createdAt              DateTime              @default(now())

  @@index([state, createdAt])
  @@map("hubspot_writebacks")
}

model HubSpotWritebackSettings {
  id              String  @id @default("global")
  autoModeEnabled Boolean @default(false)

  @@map("hubspot_writeback_settings")
}

model SopDocument {
  id               String                      @id @default(cuid())
  originalFilename String
  contentType      String
  byteSize         Int
  storagePath      String
  uploadedAt       DateTime                    @default(now())
  processingStatus SopDocumentProcessingStatus @default(PROCESSING)
  failureMessage   String?
  chunks           SopChunk[]
  llmCalls         LlmCall[]

  @@index([processingStatus, uploadedAt])
  @@map("sop_documents")
}

model SopChunk {
  id            String                      @id @default(cuid())
  sopDocumentId String
  sopDocument   SopDocument                 @relation(fields: [sopDocumentId], references: [id], onDelete: Cascade)
  ordinal       Int
  text          String
  embedding     Unsupported("vector(1024)")

  @@unique([sopDocumentId, ordinal])
  @@map("sop_chunks")
}

model LlmCall {
  id                    String              @id @default(cuid())
  provider              LlmCallProvider
  modelAlias            String
  modelSnapshot         String
  source                LlmCallSource       @default(PRODUCTION)
  inputTokens           Int?
  outputTokens          Int?
  cacheCreationTokens   Int?
  cacheReadTokens       Int?
  totalTokens           Int?
  costUsd               Decimal?            @db.Decimal(12, 8)
  latencyMs             Int
  status                LlmCallStatus       @default(OK)
  errorMessage          String?
  hubSpotWorkflowRunId  String?
  hubSpotWorkflowRun    HubSpotWorkflowRun? @relation(fields: [hubSpotWorkflowRunId], references: [id], onDelete: SetNull)
  sopDocumentId         String?
  sopDocument           SopDocument?        @relation(fields: [sopDocumentId], references: [id], onDelete: SetNull)
  createdAt             DateTime            @default(now())

  @@index([source, createdAt])
  @@index([provider, modelAlias, createdAt])
  @@map("llm_calls")
}
