// Prisma schema for Triage OS infrastructure baseline.
//
// This file deliberately defines no product/domain models. It exists so
// Prisma client generation, migrations, and the pgvector extension are
// wired up. Tracer feature slices add real models when they need them.
//
// In Prisma 7 the `url` no longer lives in the datasource block — the
// connection URL is read from the process environment by `prisma.config.ts`
// for migration commands, and is supplied to the runtime PrismaClient via a
// driver adapter (@prisma/adapter-pg).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum HubSpotWebhookEventProcessingStatus {
  NEW        @map("new")
  PROCESSING @map("processing")
  PROCESSED  @map("processed")
  FAILED     @map("failed")
  IGNORED    @map("ignored")
}

enum HubSpotWorkflowRunStatus {
  IN_PROGRESS @map("in_progress")
  SUCCEEDED   @map("succeeded")
  FAILED      @map("failed")
}

enum HubSpotWorkflowRunOutcome {
  NO_WRITEBACK_NEEDED @map("no_writeback_needed")
}

model HubSpotWebhookEvent {
  id               String                              @id @default(cuid())
  dedupeKey        String                              @unique
  rawWebhook       Json
  normalizedEvent  Json
  receivedAt       DateTime                            @default(now())
  processingStatus HubSpotWebhookEventProcessingStatus @default(NEW)
  processedAt      DateTime?
  workflowRun      HubSpotWorkflowRun?

  @@index([processingStatus, receivedAt])
  @@map("hubspot_webhook_events")
}

model HubSpotWorkflowRun {
  id                    String                    @id @default(cuid())
  hubSpotWebhookEventId String                    @unique
  hubSpotWebhookEvent   HubSpotWebhookEvent       @relation(fields: [hubSpotWebhookEventId], references: [id], onDelete: Cascade)
  status                HubSpotWorkflowRunStatus  @default(IN_PROGRESS)
  outcome               HubSpotWorkflowRunOutcome?
  enrichmentInputContext Json?
  failureMessage        String?
  completedAt           DateTime?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  @@index([status, createdAt])
  @@map("hubspot_workflow_runs")
}
