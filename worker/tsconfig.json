{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "../dist",
    "rootDir": "..",
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2022",
    "lib": ["ES2022"],
    "incremental": false,
    "declaration": false,
    "sourceMap": true,
    "jsx": "preserve"
  },
  "include": [
    "**/*.ts",
    "../services/**/*.ts",
    "../lib/**/*.ts"
  ],
  "exclude": ["node_modules", "**/*.tsx"]
}
