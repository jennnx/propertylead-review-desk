{
  "name": "propertylead-review-desk",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "test": "vitest run",
    "lint": "eslint",
    "postinstall": "prisma generate --no-hints",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:status": "prisma migrate status",
    "db:check": "tsx scripts/db-check.ts",
    "health:check": "tsx scripts/health-check.ts",
    "queue:verify": "tsx scripts/queue-verify.ts",
    "worker:dev": "tsx watch worker/index.ts",
    "worker:build": "tsc -p worker/tsconfig.json",
    "worker:start": "node dist/worker/index.js",
    "sandcastle": "tsx .sandcastle/main.mts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@hugeicons/core-free-icons": "^4.1.2",
    "@hugeicons/react": "^1.1.6",
    "@langchain/textsplitters": "^1.0.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bullmq": "^5.76.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "ioredis": "^5.10.1",
    "next": "16.2.6",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.5.10",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
